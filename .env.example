# Copy to .env and fill in. NEVER commit a populated .env.

# ── Supabase Postgres ────────────────────────────────────────────────
# From the Supabase dashboard → Project Settings → Database → Connection string
# Use the "session" pooler (port 6543) for the runtime app, or direct (5432)
# when running Flyway migrations.
SUPABASE_DB_URL=jdbc:postgresql://aws-0-eu-west-2.pooler.supabase.com:6543/postgres?sslmode=require
SUPABASE_DB_USER=postgres.YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=replace-me

# ── Redis ────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT + crypto ─────────────────────────────────────────────────────
# Must be ≥ 32 bytes
JWT_SECRET=change-me-to-a-random-string-at-least-32-bytes
BCRYPT_PEPPER=change-me-to-a-server-side-pepper

# ── AI ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
